#!/usr/bin/env sh
set -eu

ROOT="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
if [ "${GERBIL:-}" ]; then
  GERBIL_BIN="$GERBIL"
elif command -v gxi >/dev/null 2>&1; then
  GERBIL_BIN="$(command -v gxi)"
elif [ -x /usr/local/bin/gxi ]; then
  GERBIL_BIN=/usr/local/bin/gxi
elif [ -x /opt/homebrew/bin/gxi ]; then
  GERBIL_BIN=/opt/homebrew/bin/gxi
else
  GERBIL_BIN=gxi
fi

GERBIL_LOADPATH="${GERBIL_LOADPATH:-$ROOT/src}"
export GERBIL_LOADPATH

exec "$GERBIL_BIN" "$ROOT/bin/gerbil-scheme-harness.ss" "$@"
