{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-semantic-protocols.local/schemas/semantic-language-evidence.v1.schema.json",
  "title": "Semantic Language Evidence",
  "description": "Generic language evidence packet for parser, runtime, standard library, capability, and compiler-evidence facts that do not require a specialized schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "namespace",
    "authority",
    "evidenceGrade",
    "quality",
    "query",
    "facts",
    "missing",
    "witness",
    "next"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-language-evidence"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "const": "1"
    },
    "languageId": {
      "type": "string",
      "minLength": 1
    },
    "providerId": {
      "type": "string",
      "minLength": 1
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "authority": {
      "type": "string",
      "minLength": 1
    },
    "evidenceGrade": {
      "enum": ["fact", "unknown"]
    },
    "quality": {
      "enum": ["verified", "insufficient"]
    },
    "query": {
      "type": "string"
    },
    "facts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/languageEvidenceFact"
      }
    },
    "missing": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "witness": {
      "type": "string",
      "minLength": 1
    },
    "next": {
      "type": "string",
      "pattern": "^search "
    }
  },
  "$defs": {
    "languageEvidenceFact": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "summary",
        "evidenceGrade",
        "witness",
        "next",
        "terms",
        "details",
        "selectors",
        "agentScenario",
        "intent",
        "qualitySignals",
        "failureCases"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidenceGrade": {
          "enum": ["fact", "unknown"]
        },
        "witness": {
          "type": "string",
          "minLength": 1
        },
        "next": {
          "type": "string",
          "pattern": "^search "
        },
        "terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "details": {
          "type": "object"
        },
        "selectors": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "agentScenario": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "qualitySignals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failureCases": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  }
}
