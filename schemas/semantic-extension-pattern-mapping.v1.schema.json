{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent.semantic-protocols/schemas/semantic-extension-pattern-mapping.v1.schema.json",
  "title": "Semantic Extension Pattern Mapping",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "namespace",
    "authority",
    "evidenceGrade",
    "quality",
    "query",
    "patternMapping",
    "missing",
    "witness",
    "next"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-extension-pattern-mapping"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "type": "string",
      "minLength": 1
    },
    "languageId": {
      "type": "string",
      "minLength": 1
    },
    "providerId": {
      "type": "string",
      "minLength": 1
    },
    "namespace": {
      "const": "pattern"
    },
    "authority": {
      "const": "executable-pattern"
    },
    "evidenceGrade": {
      "enum": ["fact", "unknown"]
    },
    "quality": {
      "enum": ["verified", "partial", "insufficient"]
    },
    "query": {
      "type": "string"
    },
    "patternMapping": {
      "anyOf": [
        {
          "$ref": "#/$defs/patternMapping"
        },
        {
          "const": false
        },
        {
          "type": "null"
        }
      ]
    },
    "missing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "witness": {
      "type": "string"
    },
    "next": {
      "type": "string"
    }
  },
  "$defs": {
    "patternMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "extension",
        "focus",
        "origin",
        "sourceRef",
        "sourceOwners",
        "agentScenario",
        "intent",
        "selectors",
        "minimalForms",
        "failureCases",
        "qualitySignals",
        "witness"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "extension": {
          "type": "string",
          "minLength": 1
        },
        "focus": {
          "type": "string"
        },
        "origin": {
          "enum": ["direct", "inherited", "provider", "ambient"]
        },
        "via": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "importWitness": {
          "$ref": "#/$defs/importWitness"
        },
        "sourceRef": {
          "$ref": "#/$defs/sourceRef"
        },
        "selectorResolver": {
          "$ref": "#/$defs/selectorResolver"
        },
        "sourceLookup": {
          "$ref": "#/$defs/sourceLookup"
        },
        "agentReadOrder": {
          "$ref": "#/$defs/agentReadOrder"
        },
        "agentAction": {
          "$ref": "#/$defs/agentAction"
        },
        "sourceOwners": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agentScenario": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "selectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceSelector"
          }
        },
        "minimalForms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/formMapping"
          }
        },
        "failureCases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failureCase"
          }
        },
        "qualitySignals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "witness": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "importWitness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "module", "minimalImport", "evidence"],
      "properties": {
        "status": {
          "enum": ["verified", "partial", "unknown"]
        },
        "module": {
          "type": "string",
          "minLength": 1
        },
        "minimalImport": {
          "type": "string"
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "activation": {
          "type": "string"
        },
        "dependencyChain": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "manager",
        "package",
        "dependency",
        "repository",
        "pathPolicy",
        "selectorScheme"
      ],
      "properties": {
        "kind": {
          "enum": [
            "package-manager-source",
            "package-manager-download",
            "provider-source"
          ]
        },
        "manager": {
          "type": "string",
          "minLength": 1
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "dependency": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "pathPolicy": {
          "enum": ["runtime-resolved", "repository-relative"]
        },
        "selectorScheme": {
          "type": "string",
          "minLength": 1
        },
        "localSource": {
          "$ref": "#/$defs/localSource"
        },
        "repositorySource": {
          "$ref": "#/$defs/repositorySource"
        },
        "indexHint": {
          "$ref": "#/$defs/indexHint"
        }
      }
    },
    "localSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "manager", "rootHint", "package", "status", "owner"],
      "properties": {
        "kind": {
          "const": "gerbil-package-source"
        },
        "manager": {
          "type": "string",
          "minLength": 1
        },
        "rootHint": {
          "type": "string",
          "minLength": 1
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
      "status": {
        "type": "string",
        "minLength": 1
      },
      "missingAction": {
        "const": "install-package-before-repository-fallback"
      },
      "installHint": {
        "type": "string",
        "minLength": 1
      },
      "owner": {
        "type": "string",
          "minLength": 1
        }
      }
    },
    "repositorySource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "vcs", "repository", "url", "status", "owner"],
      "properties": {
        "kind": {
          "const": "git-repository"
        },
        "vcs": {
          "const": "git"
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "indexHint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "backend", "mode"],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "backend": {
          "type": "string",
          "minLength": 1
        },
      "mode": {
        "const": "local-source-before-git"
      },
      "packageManager": {
        "type": "string",
        "minLength": 1
      },
      "missingLocalAction": {
        "const": "install-package-before-repository-fallback"
      },
      "fallbackPolicy": {
        "const": "repository-source-after-install-check"
      }
    }
  },
    "selectorResolver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheme", "status", "querySelector", "sourceRef"],
      "properties": {
        "scheme": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "logical-selector"
        },
        "querySelector": {
          "const": "not-direct"
        },
        "sourceRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sourceLookup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order", "localSource", "repositorySource", "indexHint"],
      "properties": {
      "order": {
        "const": "local-source-before-git"
      },
      "missingLocalAction": {
        "const": "install-package-before-repository-fallback"
      },
      "fallbackPolicy": {
        "const": "repository-source-after-install-check"
      },
      "localSource": {
        "$ref": "#/$defs/localSource"
        },
        "repositorySource": {
          "$ref": "#/$defs/repositorySource"
        },
        "indexHint": {
          "$ref": "#/$defs/indexHint"
        }
      }
    },
    "agentReadOrder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first", "second", "third", "fourth", "fifth", "sixth"],
      "properties": {
        "first": {
          "const": "agentScenario"
        },
        "second": {
          "const": "agentSteering"
        },
        "third": {
          "const": "selectorResolver"
        },
        "fourth": {
          "const": "minimalForms"
        },
        "fifth": {
          "const": "failureCases"
        },
        "sixth": {
          "const": "quality"
        }
      }
    },
    "agentAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "selectorUse", "quality", "avoid"],
      "properties": {
        "action": {
          "const": "use-minimalForms-before-editing"
        },
      "selectorUse": {
        "const": "source-anchor"
      },
      "missingLocalAction": {
        "const": "install-package-before-repository-fallback"
      },
      "fallback": {
        "const": "repository-source-after-install-check"
      },
        "quality": {
          "enum": ["verified", "partial", "insufficient"]
        },
        "avoid": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sourceSelector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "symbol", "selector"],
      "properties": {
        "role": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "selector": {
          "type": "string"
        }
      }
    },
    "formMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "symbol", "selector", "template"],
      "properties": {
        "role": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "selector": {
          "type": "string"
        },
        "template": {
          "$ref": "#/$defs/formTemplate"
        }
      }
    },
    "formTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["head", "operands", "keywords"],
      "properties": {
        "head": {
          "type": "string"
        },
        "operands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "failureCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "selectors"],
      "properties": {
        "id": {
          "type": "string"
        },
        "risk": {
          "type": "string"
        },
        "correction": {
          "type": "string"
        },
        "riskKind": {
          "type": "string"
        },
        "badPattern": {
          "type": "string"
        },
        "correctiveAction": {
          "type": "string"
        },
        "selectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
