{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent.semantic-protocols/schemas/semantic-extension-pattern-mapping.v1.schema.json",
  "title": "Semantic Extension Pattern Mapping",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaId",
    "schemaVersion",
    "protocolId",
    "protocolVersion",
    "languageId",
    "providerId",
    "namespace",
    "authority",
    "evidenceGrade",
    "quality",
    "query",
    "patternMapping",
    "missing",
    "witness",
    "next"
  ],
  "properties": {
    "schemaId": {
      "const": "agent.semantic-protocols.semantic-extension-pattern-mapping"
    },
    "schemaVersion": {
      "const": "1"
    },
    "protocolId": {
      "const": "agent.semantic-protocols.semantic-language"
    },
    "protocolVersion": {
      "type": "string",
      "minLength": 1
    },
    "languageId": {
      "type": "string",
      "minLength": 1
    },
    "providerId": {
      "type": "string",
      "minLength": 1
    },
    "namespace": {
      "const": "pattern"
    },
    "authority": {
      "const": "executable-pattern"
    },
    "evidenceGrade": {
      "enum": ["fact", "unknown"]
    },
    "quality": {
      "enum": ["verified", "partial", "insufficient"]
    },
    "query": {
      "type": "string"
    },
    "patternMapping": {
      "anyOf": [
        {
          "$ref": "#/$defs/patternMapping"
        },
        {
          "const": false
        },
        {
          "type": "null"
        }
      ]
    },
    "missing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "witness": {
      "type": "string"
    },
    "next": {
      "type": "string"
    }
  },
  "$defs": {
    "patternMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "extension",
        "focus",
        "sourceRef",
        "sourceOwners",
        "agentScenario",
        "intent",
        "selectors",
        "minimalForms",
        "failureCases",
        "qualitySignals",
        "witness"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "extension": {
          "type": "string",
          "minLength": 1
        },
        "focus": {
          "type": "string"
        },
        "sourceRef": {
          "$ref": "#/$defs/sourceRef"
        },
        "sourceOwners": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "agentScenario": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "selectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceSelector"
          }
        },
        "minimalForms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/formMapping"
          }
        },
        "failureCases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failureCase"
          }
        },
        "qualitySignals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "witness": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "manager",
        "package",
        "dependency",
        "repository",
        "pathPolicy",
        "selectorScheme"
      ],
      "properties": {
        "kind": {
          "enum": ["package-manager-download", "provider-source"]
        },
        "manager": {
          "type": "string",
          "minLength": 1
        },
        "package": {
          "type": "string",
          "minLength": 1
        },
        "dependency": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "pathPolicy": {
          "enum": ["runtime-resolved", "repository-relative"]
        },
        "selectorScheme": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sourceSelector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "symbol", "selector"],
      "properties": {
        "role": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "selector": {
          "type": "string"
        }
      }
    },
    "formMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "symbol", "selector", "template"],
      "properties": {
        "role": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "selector": {
          "type": "string"
        },
        "template": {
          "$ref": "#/$defs/formTemplate"
        }
      }
    },
    "formTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["head", "operands", "keywords"],
      "properties": {
        "head": {
          "type": "string"
        },
        "operands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "failureCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "selectors"],
      "properties": {
        "id": {
          "type": "string"
        },
        "risk": {
          "type": "string"
        },
        "correction": {
          "type": "string"
        },
        "riskKind": {
          "type": "string"
        },
        "badPattern": {
          "type": "string"
        },
        "correctiveAction": {
          "type": "string"
        },
        "selectors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
